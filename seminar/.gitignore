# Ignore everything by default
*

# Include these file types
!*.py
!Dockerfile
!.gitignore
!README.md

# Include data folder
!data/
!data/**

# Include models folder
!models/
!models/**

# Include utils folder
!utils/
!utils/**

# Exclude Python cache
__pycache__/
*.pyc

# Exclude numpy files (too large, not needed for repo)
*.npy
*.npz
